<?xml version="1.0" encoding="utf-8"?>

<odoo>
 <!-- List View -->
    <record id="view_hotel_guestregistration_list" model="ir.ui.view">
        <field name="name">hotel.guestregistration.list</field>
        <field name="model">hotel.guestregistration</field>
        <field name="arch" type="xml">
            
            <list string="Guest Registrations" limit="50">
                <header>
                    <button name="action_refresh_guest_list"
                        type="object"
                        string="Refresh"
                        icon="fa-refresh"
                        class="btn-primary"
                        display="always"/>
                </header>

                <field name="grc_id_display"/> 
                <field name="create_date_ampm"/>
                <field name="room_id"/>
                <field name="roomtname"/>
                <field name="guest_id"/>      
                <field name="state"/>   
                <field name="datefromsched_ampm"/>   
                <field name="datetosched_ampm"/>   
                <field name="total_amount_appliedstr" sum="Grand Total"  class="o_list_number"/>              
                <field name="actualpax"/>
                <field name="creator_login" string="Created By" readonly="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_hotel_guestregistration_form" model="ir.ui.view">
        <field name="name">hotel.guestregistration.form</field>
        <field name="model">hotel.guestregistration</field>
        <field name="arch" type="xml">
            <form string="Guest Registration">
                <header>
                    <field name="state" widget="statusbar" nolabel="1"/>

  	                <button name="action_reserve" 
                        string="Reserve" 
                        type="object" 
                        invisible="state != 'DRAFT'"
                        confirm="Tag registration as RESERVED?"
                        icon="fa-calendar-check-o"
                        class="oe_highlight"/>

                    <button name="action_checkin" 
                        string="Check IN" 
                        type="object" 
                        invisible="state == 'CHECKEDIN' or state == 'CHECKEDOUT' or state=='CANCELLED'"
                        confirm="Tag registration as CHECKED IN?"
                        icon="fa-key"
                        class="oe_highlight"/>

                    <button name="action_checkout" 
                        string="Check OUT" 
                        type="object" 
                        invisible="state != 'CHECKEDIN'"
                        confirm="Tag registration as CHECKED OUT?"
                        icon="fa-sign-out"
                        class="oe_highlight"/>

                    <button name="action_cancel" 
                        string="Cancel Registration" 
                        type="object" 
                        confirm="Tag registration as CANCELLED?"
                        invisible="state != 'DRAFT' and state!= 'RESERVED'"
                        icon="fa-times"
                        class="oe_highlight oe_right"/>  

                    <button name="action_check_availability" 
                        string="Check Availability" 
                        type="object" 
                        invisible="state != 'DRAFT' and state!= 'RESERVED'"
                        icon="fa-calendar-check-o"
                        class="oe_highlight oe_right"/>  

                </header>
                <sheet>
                    <group col="3">
                        <group>
                            <field name="grc_id_display" string="GRC # " class="fw-bold" readonly="1"/>
                            <field name="guest_id" string="Guest" readonly="state!='DRAFT'"/>
                            <field name="room_id" string="Room #" readonly="state!='DRAFT'"/>
                            <field name="roomtname" string="Room Type" readonly="1"/>
                            <field name="actualpax" string="Actual PAX" readonly="state!='DRAFT'"/>
                        </group>
                        <group>
                            <field name="create_date_ampm" string="Date" readonly="1"/>
                            <field name="datefromsched" string="Scheduled Check In" readonly="state!='DRAFT'"/>
                            <field name="datetosched" string="Scheduled Check Out" readonly="state!='DRAFT'"/>
                            <field name="total_amount_appliedstr" readonly="1"/>  
                        </group>
                        <group>
                            <field name="details" widget="text" colspan="2" readonly="state!='DRAFT'"/>
                            <field name="creator_login" string="Created By" readonly="1"/>
                        </group>
                    </group>


                    <notebook>
                        <page string="Guest Bill">
                            <header>
                                <!-- New Wizard Button -->
                                <button name="%(action_roombillrecord_new_wizard)d"  
                                    string="New Room Transaction"
                                    type="action"
                                    class="btn-primary float-end"
                                    invisible="state != 'CHECKEDIN'"
                                    icon="fa-plus"
                                    context="{'default_guestregistration_id': id}"/>

                                <button name="%(action_report_bill)d"
                                    string="Print Bill"
                                    type="action"
                                    class="btn-primary float-end"
                                    invisible="state == 'CANCELLED'"
                                    confirm="Print Bill"
                                    icon="fa-print"/>

                                <button name="%(action_report_bill2)d"
                                    string="Print Bill (MultiPage)"
                                    type="action"
                                    class="btn-primary float-end"
                                    invisible="state == 'CANCELLED'"
                                    confirm="Print Bill"
                                    icon="fa-print"/>

                                <button name="%(hotel.action_hotel_email_guestbill_wizard)d" 
                                    string="Email Guest Bill" 
                                    type="action" 
                                    class="oe_highlight"
                                    icon="fa-envelope"
                                    context="{
                                        'default_res_id': id, 
                                        'default_email_to': guest_id.email, 
                                        'default_subject': 'Updated Room Bill'
                                    }"/>

                            </header>

                            <field name="roombill_ids">
                                <list create="false" edit="false" delete="false" readonly="1" limit="65">
                                    <!-- <header>
                                        <button name="action_finalize" 
                                            string="Finalize" 
                                            type="object" 
                                            invisible="state != 'DRAFT'"
                                            confirm="Tag Bill Record as FINAL?"     
                                            class="oe_highlight"/>
                                    </header> -->


                                    <field name="line_no" options="{'format': '05d'}" width="30px"/>
                                    <field name="dateapplied_fmt" string="Date" width="100%"/>

                                    <field name="document_id" string="Doc." width="40px"/>
                                    <field name="documentno" string="No."  width="40px" />
                                    <field name="charge_id" string="Account Title"  width="120%"/>
                                    <field name="details" string="Details"  width="250"/>
                                    <field name="amountapplied"/>

                                    <field name="state"
                                        decoration-muted="state == 'CANCELLED'"
                                        decoration-info="state == 'FINAL'"
                                        decoration-bf="state == 'FINAL'" 
                                        decoration-warning="state == 'DRAFT'"/>
                                    
                                    <field name="debitamt" sum="Total Debit" class="o_list_number"/>
                                    <field name="creditamt" sum="Total Credit" class="o_list_number"/>
                                    
                                    <!-- Formatted Balance -->
                                    <field name="diffamt" sum="Total Balance"  class="o_list_number"/>



                                    <!-- Edit button only visible for DRAFT rows -->
                                    <button name="action_edit_roombill" 
                                        type="object" 
                                        icon="fa-edit" 
                                        title="Edit Room Bill Record"
                                        invisible="state != 'DRAFT'"
                                        class="oe_highlight"/> 

                                    
                                    <!-- Delete button only visible for CANCELLED rows -->
                                     <button name="action_delete_roombill"
                                        type="object"
                                        class="btn" 
                                        icon="fa-trash"
                                        title="Delete Record"
                                        confirm="Delete Record?"
                                        invisible="state != 'CANCELLED'"/> 


                                </list>
                            </field>
                        </page>
                    </notebook>

                </sheet>

    

            </form>
        </field>    
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="action_hotel_active_guestregistration">
    <field name="name">Active Guest Registrations</field>
    <field name="res_model">hotel.guestregistration</field>
    <field name="view_mode">list,form</field>
    <field name="views">[
       (ref('view_hotel_guestregistration_list'), 'list'),
       (ref('view_hotel_guestregistration_form'), 'form')
    ]</field>
    <field name="domain">[('state','in',['DRAFT','RESERVED','CHECKEDIN'])]</field>
    <field name="context">{'create': True}</field>  
    </record>

    <!-- actions opening views on models -->
    <record model="ir.actions.act_window" id="action_hotel_inactive_guestregistration">
    <field name="name">Inactive Guest Registrations</field>
    <field name="res_model">hotel.guestregistration</field>
    <field name="view_mode">list,form</field>
    <field name="views">[
       (ref('view_hotel_guestregistration_list'), 'list'),
       (ref('view_hotel_guestregistration_form'), 'form')
    ]</field>
    <field name="domain">[('state','in',['CHECKEDOUT','CANCELLED'])]</field>
    <field name="context">{'create': False}</field>  
    </record>

  <menuitem 
      name="Active Guest Registrations" 
      id="menu_hotel_active_guestregistration" 
      parent="menu_hotel_guestregistration_list"
      action="action_hotel_active_guestregistration" 
      sequence="20"/>

  <menuitem 
      name="Inactive Guest Registrations" 
      id="menu_hotel_inactive_guestregistration" 
      parent="menu_hotel_guestregistration_list"
      action="action_hotel_inactive_guestregistration" 
      sequence="30"/>      

</odoo>